# BT OS — environment configuration
#
# Copy to `.env.local` (gitignored) for local use, or paste these into
# Railway → Variables. Any value set here is used when the Settings screen
# has no entry for it, so you never have to re-enter keys on a fresh deploy.
# Leave a line out to skip that integration.
#
# NEVER commit real values. `.env.local` and `.env*` are gitignored on purpose.

# --- Deployment / hosting ---
# Password gate for public deploys (Railway). Unset = open (local only).
APP_PASSWORD=
# Persistent SQLite + uploads location (Railway volume mount).
BTOS_DATA_DIR=

# --- Affiliate (Impact Radius) ---
IMPACT_SID=
IMPACT_TOKEN=

# --- AI (Anthropic — script + strategist generation) ---
ANTHROPIC_API_KEY=

# --- YouTube Data API (exact subscriber/view counts; optional) ---
YT_API_KEY=

# --- Instagram (sessionid cookie for live metrics) ---
IG_SESSION=

# --- Google OAuth (AdSense revenue sync) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set only if you want to skip the in-app "Connect AdSense" flow.
GOOGLE_REFRESH_TOKEN=

# --- Account handles (default to @CyberWithBen if unset) ---
YT_HANDLE=@CyberWithBen
IG_HANDLE=@CyberWithBen
TT_HANDLE=@CyberWithBen
